{
  "id": "anilist-notifications",
  "name": "AniList Notifications",
  "version": "2.0.1",
  "manifestURI": "https://raw.githubusercontent.com/Seanime-contributions/Seanime-Providers/refs/heads/main/src/plugins/anilist-notifications/manifest.json",
  "language": "typescript",
  "type": "plugin",
  "description": "View your AniList notifications.",
  "author": "Pal",
  "icon": "https://raw.githubusercontent.com/Seanime-contributions/Seanime-Providers/refs/heads/main/public/anilist.ico",
  "website": "",
  "lang": "multi",
  "payloadURI": "https://raw.githubusercontent.com/arnislvdev/monarch-providers/refs/heads/main/src/plugins/anilist-notifications/provider.ts",
  "plugin": {
    "version": "1",
    "permissions": {
      "scopes": ["anilist-token", "database"],
      "allow": {
        "networkAccess": {
          "allowedDomains": ["anilist.co", "graphql.anilist.co"],
          "reasoning": "Required to fetch notifications from AniList GraphQL API"
        }
      }
    }
  },
  "isDevelopment": false
}
